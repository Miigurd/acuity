# =============================================================================
# ACUITY — Environment Configuration
# =============================================================================

# --- Scraper Settings ---
CHROME_USER_DATA_DIR=./data/chrome_session
CHROME_VERSION_MAIN=144
DEFAULT_MAX_SCROLLS=10
DEFAULT_SCROLL_DELAY=4

# --- Target Facebook Group URLs (comma-separated) ---
TARGET_URLS=https://www.facebook.com/groups/your-community-group

# --- Database ---
DATABASE_URL=sqlite:///data/acuity.db

# --- Flask / Web App ---
FLASK_SECRET_KEY=change-this-to-a-random-secret
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
